# Server
PORT=5173
DEFAULT_CITY=Nanjing
DEFAULT_CENTER=118.796877,32.060255
DEFAULT_ZOOM=12

# AMap frontend Web JS API.
# 高德控制台选择：Web端(JS API)
AMAP_JS_API_KEY=
AMAP_SECURITY_JS_CODE=

# OpenAI-compatible language model endpoint.
# Keep this on the backend only. Do not put it in config.js or app.js.
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

# AMap Skill adapter mode.
# jsapi: frontend uses AMap JS API plugins for search/route display.
# web-service: reserved for server-side AMap Web Service calls.
AMAP_SKILL_MODE=jsapi

# Required if you want backend to truly call AMap Web Service for LBS search/route.
AMAP_WEB_SERVICE_KEY=
